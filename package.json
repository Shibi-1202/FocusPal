{
  "name": "focuspal-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "FocusPal - A smart floating productivity companion",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:desktop": "pnpm --filter @focuspal/desktop dev",
    "dev:backend": "pnpm --filter @focuspal/backend dev",
    "build:shared": "pnpm --filter @focuspal/shared build",
    "build:desktop": "pnpm --filter @focuspal/desktop build",
    "build:backend": "pnpm --filter @focuspal/backend build",
    "build:all": "pnpm -r build",
    "start:desktop": "pnpm --filter @focuspal/desktop start",
    "start:backend": "pnpm --filter @focuspal/backend start",
    "test": "pnpm -r test",
    "test:monorepo": "./scripts/test-monorepo.sh",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "postinstall": "pnpm build:shared"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "@types/node": "^20.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}
