{
  "name": "focuspal-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "FocusPal - A smart floating productivity companion",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:desktop": "pnpm --filter @focuspal/desktop dev",
    "build:desktop": "pnpm --filter @focuspal/desktop build",
    "build-win": "pnpm --filter @focuspal/desktop build-win",
    "build:linux": "pnpm --filter @focuspal/desktop build-linux",
    "build:all": "pnpm -r build",
    "publish:apt": "./scripts/publish-apt.sh",
    "start:desktop": "pnpm --filter @focuspal/desktop start",
    "test": "pnpm -r test",
    "test:monorepo": "./scripts/test-monorepo.sh",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean && rm -rf node_modules"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "@types/node": "^20.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}
